# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Google Sheets – publish your sheet (File > Share > Publish to web)
# then paste the Sheet ID from its URL here.
VITE_SHEET_ID=your_google_sheet_id_here

# The exact tab name in your Google Sheet (case-sensitive)
VITE_SHEET_NAME=Deals

# WhatsApp business number (international format, no + or spaces)
VITE_WHATSAPP=919014193407

# Google Apps Script Web App URL (for admin writes – see scripts/apps-script.gs)
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Admin panel password (keep this secret; set in Netlify env vars for prod)
VITE_ADMIN_PASSWORD=changeme123

# Site display name
VITE_SITE_NAME=Padmavathi Sarees
